# Postgres connection (Coolify-managed Postgres in prod; local docker-compose.dev.yml in dev)
DATABASE_URL=postgres://receiptcash:receiptcash@localhost:5432/receiptcash

# HTTP server
PORT=8080

# JWT access-token signing secret. Generate with: openssl rand -base64 48
JWT_SECRET=changeme

# Comma-separated list of allowed CORS origins (web app + local dev)
CORS_ORIGINS=http://localhost:3000,https://receiptcash.3pandalabs.com

# Cloudflare R2 (S3-compatible). Bucket must be created ahead of time; see nrighar/infra/r2-setup.md for the pattern
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=receiptcash-documents
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Reward rate: percent of receipt total credited as points (2 = 2%, i.e. 100 points per $1 at 2%)
REWARD_RATE_PERCENT=2

# AWS Textract (receipt OCR) - IAM user receiptcash-textract, same one the old Edge Function used
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
